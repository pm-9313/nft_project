{
  "files.autoSave": "off", // Automatically saves files after a delay
  "editor.minimap.enabled": false, // Disables the minimap
  "editor.wordWrap": "off", // Enables word wrapping
  "files.exclude": {
    // Hides unnecessary files from the file explorer
    "**/.DS_Store": true,
    "**/node_modules": true,
    "**/artifacts": true,
    "**/cache": true,
    ".vscode": true
  },
  "editor.tabSize": 2, // Sets tab size to 2 spaces
  "editor.formatOnSave": false, // Automatically formats code on save
  "[solidity]": {
    "editor.defaultFormatter": "JuanBlanco.solidity",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": null,
    "editor.formatOnSave": true
  },
  "solidity.linter": "solhint",
  "solidity.compileUsingRemoteVersion": "0.8.28",
  "editor.rulers": [80, 120],
  "terminal.integrated.profiles.windows": {
    "GitHub CLI": {
      "path": "C:\\Program Files\\Git\\bin\\bash.exe" // Update path if GitHub CLI uses a different shell
    },
    "PowerShell": {
      "path": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe"
    }
  },
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.profiles.linux": {
    "GitHub CLI": {
      "path": "/usr/bin/gh"
    },
    "Default Shell": {
      "path": "/bin/bash"
    }
  },
  "terminal.integrated.profiles.osx": {
    "GitHub CLI": {
      "path": "/usr/local/bin/gh"
    },
    "Default Shell": {
      "path": "/bin/zsh"
    }
  },
  "terminal.integrated.defaultProfile.linux": "GitHub CLI",
  "terminal.integrated.defaultProfile.osx": "GitHub CLI",
  "terminal.integrated.defaultProfileCondition": {
    "profiles": {
      "GitHub CLI": "exists(/usr/bin/gh) || exists(/usr/local/bin/gh) || exists(C:\\Program Files\\Git\\bin\\bash.exe)"
    },
    "fallbacks": {
      "windows": "PowerShell",
      "linux": "Default Shell", 
      "osx": "Default Shell"  
    }
  },
  "task.presentation": {
    "reveal": "never",
    "echo": false,
    "focus": false,
    "panel": "dedicated"
  }
}
